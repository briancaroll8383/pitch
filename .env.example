# Copy this to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: Spotify ───────────────────────────────────────────────────────
# Adds artist popularity, follower count, genres, top tracks, and discography.
# Get free credentials in 5 minutes: https://developer.spotify.com/dashboard
# 1. Log in → Create App → set redirect URI to http://localhost
# 2. Copy Client ID and Client Secret below
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Optional: Last.fm ───────────────────────────────────────────────────────
# Adds listener count, playcount, tags, similar artists, and bio.
# Free API key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required for production: random secret for session signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
DEBUG=true
